<!DOCTYPE html>
<html>
<head>
<title>HTML Text Formatting Tags</title>
<style>
table{
border-collapse: collapse;
width:80%;
margin:auto;
}

th,td{
border:1px solid black;
padding:10px;
text-align:center;
}

th{
background-color:#f2f2f2;
}
</style>
</head>

<body>

<h1 style="text-align:center;">HTML Text Formatting Tags</h1>

<table>
<tr>
<th>Tag</th>
<th>Description</th>
<th>Example</th>
</tr>

<tr>
<td>b</td>
<td>Bold text</td>
<td><b>This is bold</b></td>
</tr>

<tr>
<td>strong</td>
<td>Important text</td>
<td><strong>Important</strong></td>
</tr>

<tr>
<td>i</td>
<td>Italic text</td>
<td><i>Italic</i></td>
</tr>

<tr>
<td>em</td>
<td>Emphasized text</td>
<td><em>Emphasis</em></td>
</tr>

<tr>
<td>mark</td>
<td>Marked text</td>
<td><mark>Highlighted</mark></td>
</tr>

<tr>
<td>small</td>
<td>Small text</td>
<td><small>Small text</small></td>
</tr>

<tr>
<td>del</td>
<td>Deleted text</td>
<td><del>Deleted</del></td>
</tr>

<tr>
<td>ins</td>
<td>Inserted text</td>
<td><ins>Inserted</ins></td>
</tr>

<tr>
<td>sub</td>
<td>Subscript</td>
<td>H<sub>2</sub>O</td>
</tr>

<tr>
<td>sup</td>
<td>Superscript</td>
<td>10<sup>2</sup></td>
</tr>

</table>

</body>
</html>
